{% extends "layout.njk" %}

{% block title %}
  {{ title }}
{% endblock %}

{% block content %}
  <div class="container">
    <div>
      <form class="search-input">
        <label>Search</label>
        <input name="search" autocomplete="off" value="{{searchValue}}" placeholder="Enter search term"/>
        <button type="submit">Submit</button>
      </form>
      <table class="small-first-column clickable">
        <thead>
          <tr>
            <th>CRN</th>
            <th>First Name</th>
            <th>Last Name</th>
          </tr>
        </thead>
        <tbody>
          {% for customer in listResult.data.business.customers %}
            <tr class="{% if customer.crn === selectedCrn %}selected{% endif %}">
              <td>
                <a href="#">{{ customer.crn }}</a>
              </td>
              <td>
                <a href="#">{{ customer.firstName }}</a>
              </td>
              <td>
                <a href="#">{{ customer.lastName }}</a>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No customers found.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="divider"></div>
    <div>
      <h1>{{selectedResult.data.customer.info.name.first}}
        {{selectedResult.data.customer.info.name.last}}</h1>

      <dl>
        <dt>CRN:</dt>
        <dd>{{selectedResult.data.customer.crn}}</dd>
        <dt>Full Name:</dt>
        <dd>{{selectedResult.data.customer.info.name.title}}
          {{selectedResult.data.customer.info.name.first}}
          {{selectedResult.data.customer.info.name.middle}}
          {{selectedResult.data.customer.info.name.last}}</dd>
        <dt>Role:</dt>
        <dd>{{selectedResult.data.business.customer.role}}</dd>

      </dl>

      <table class="even-columns">
        <thead>
          <tr>
            <th>Permission</th>
            <th>Level</th>
          </tr>
        </thead>
        <tbody>
          {% for permissionGroup in selectedResult.data.business.customer.permissionGroups %}
            <tr>
              <td>{{ permissionGroup.id }}</td>
              <td>{{ permissionGroup.level }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No customers found.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}